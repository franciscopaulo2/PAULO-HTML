   <!-- Onde a palavra vai aparecer -->
    <p>A palavra atual é: <span id="minhaPalavra">Café</span></p>

    <!-- O botão que chama a função JavaScript -->
    <button onclick="mudarPalavra()">Mudar Palavra</button>

    <script>
        function mudarPalavra() {
            // Pega o elemento pelo ID
            let elemento = document.getElementById("minhaPalavra");
            
            // Verifica a palavra atual e altera
            if (elemento.innerHTML === "Café") {
                elemento.innerHTML = "Chá";
            } else {
                elemento.innerHTML = "Café";
            }
        }
    </script>
